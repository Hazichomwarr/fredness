
generator client {
  provider = "prisma-client-js"
 
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  WHOLESALE
  STAFF
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  FULFILLED
  CANCELLED
}

enum QuoteStatus {
  NEW
  CONTACTED
  NEGOTIATING
  CLOSED
  LOST
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String?
  phone        String?
  businessName String?
  role         UserRole @default(CUSTOMER)
  orders       Order[]
  quotes       Quote[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields:[productId], references:[id], onDelete:Cascade)

  url       String
  altText   String?

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  products    Product[]

  sortOrder Int @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id             String      @id @default(cuid())
  categoryId     String
  category       Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name           String
  slug           String      @unique
  sku            String      @unique
  description    String?
  images         ProductImage[]
  variants       ProductVariant[]
  weight         String?
  brand          String?
  retailPrice    Decimal     @db.Decimal(10, 2)
  wholesalePrice Decimal?    @db.Decimal(10, 2)
  minimumWholesaleQty Int?
  wholesaleMinimumLabel String?
  inventory      Int         @default(0)
  trackInventory Boolean     @default(true)
  isActive       Boolean     @default(true)
  bundleItems    BundleItem[]
  orderItems     OrderItem[]
  quoteItems     QuoteItem[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([categoryId])
  @@index([name])
}

model ProductVariant {
  id             String      @id @default(cuid())
  productId      String
  product        Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  label          String
  sku            String      @unique
  retailPrice    Decimal     @db.Decimal(10, 2)
  wholesalePrice Decimal?    @db.Decimal(10, 2)
  inventory      Int         @default(0)
  sortOrder      Int         @default(0)
  isActive       Boolean     @default(true)
  orderItems     OrderItem[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([productId])
}

model Bundle {
  id             String       @id @default(cuid())
  name           String
  slug           String       @unique
  description    String?
  imageUrl        String?
  retailPrice     Decimal      @db.Decimal(10, 2)
  wholesalePrice  Decimal?     @db.Decimal(10, 2)
  isActive        Boolean      @default(true)
  items           BundleItem[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model BundleItem {
  id        String  @id @default(cuid())
  bundleId  String
  productId String
  bundle    Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int     @default(1)

  @@unique([bundleId, productId])
  @@index([productId])
}

model Order {
  id                    String      @id @default(cuid())
  customerName          String
  customerEmail         String?
  customerPhone         String?
  notes                 String?
  status                OrderStatus @default(PENDING)

  userId                String?
  user                  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items                 OrderItem[]

  subtotal              Decimal     @db.Decimal(10, 2)
  tax                   Decimal     @default(0) @db.Decimal(10, 2)
  shipping              Decimal     @default(0) @db.Decimal(10, 2)
  total                 Decimal     @db.Decimal(10, 2)

  shippingAddress       String?
  city                  String?
  state                 String?
  zipCode               String?

  stripeCheckoutSession String?     @unique
  stripePaymentIntent   String?     @unique
 
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([userId])
  @@index([customerEmail])
  @@index([status])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String
  variantId  String?
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant    ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)
  productName String
  variantLabel String?
  sku        String
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2)
  lineTotal  Decimal @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model Quote {
  id           String      @id @default(cuid())
  userId       String?
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  name         String
  email        String
  phone        String
  businessName String
  message      String?
  status       QuoteStatus @default(NEW)
  items        QuoteItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
  @@index([email])
  @@index([status])
}

model QuoteItem {
  id             String   @id @default(cuid())
  quoteId        String
  productId      String
  quote          Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productName    String
  sku            String
  quantity       Int
  requestedPrice Decimal? @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([quoteId])
  @@index([productId])
}
